Algoritmo Act1_Lecc10_inciso1
	Definir sellos Como Entero
    
    sellos = 0
    
    Mientras sellos < 8 Hacer
        Escribir "Fuiste a la peluqueria, ganas un sello"
        
        sellos = sellos + 1
        
        Escribir "Sellos acumulados: ", sellos
    FinMientras
    
    Escribir "Felicidades, tu corte es gratis"
FinAlgoritmo
