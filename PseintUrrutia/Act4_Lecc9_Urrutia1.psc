Algoritmo Act4_Lecc9_Urrutia1
	Definir numero, i, suma Como Entero
    
    suma= 0
    
    Escribir "Ingrese un número:"
    Leer numero
    
    Para i = numero Hasta 1 Con Paso -1 Hacer
        Escribir i
        suma = suma + i
    FinPara
    
    Escribir "La suma es: ", suma
FinProceso

